{
  "$schema": "https://gkd.li/api/v2/schema",
  "id": "douyin-kid-auto-next",
  "name": "抖音 - 小朋友智能自动刷视频",
  "version": 2,
  "author": "Grok(修正整理: ChatGPT)",
  "description": "尽量在出现“重播/播放结束”等结束态控件时自动上滑到下一条；另带可选的定时兜底规则（默认关闭）。",
  "rules": [
    {
      "key": 1,
      "name": "抖音短视频自动下一条",
      "enable": true,
      "apps": ["com.ss.android.ugc.aweme"],
      "rules": [
        {
          "key": 0,
          "name": "检测结束态/重播 - 自动刷下一个",
          "enable": true,
          "activityIds": [
            "com.ss.android.ugc.aweme.main.MainActivity",
            "com.ss.android.ugc.aweme.detail.ui.DetailActivity"
          ],
          "matches": [
            "[id='com.ss.android.ugc.aweme:id/iv_replay']",
            "[id='com.ss.android.ugc.aweme:id/replay_container']",
            "[id^='com.ss.android.ugc.aweme:id/replay']",
            "[text*='重播']",
            "[text*='再看一遍']",
            "[text*='播放结束']",
            "[text*='看完这个视频']"
          ],
          "action": "global:-1",
          "interval": 800
        },
        {
          "key": 1,
          "name": "兜底：每90秒刷一次（默认关闭，避免误划）",
          "enable": false,
          "activityIds": [
            "com.ss.android.ugc.aweme.main.MainActivity",
            "com.ss.android.ugc.aweme.detail.ui.DetailActivity"
          ],
          "matches": [
            "[class='android.widget.FrameLayout']"
          ],
          "action": "global:-1",
          "interval": 90000
        }
      ]
    }
  ]
}