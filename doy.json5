{
  "$schema": "https://gkd.li/api/v2/schema",
  "id": 2026041503,
  "name": "抖音 - 小朋友自动刷下一个（定时上滑）",
  "version": 3,
  "author": "Grok(整理修正: ChatGPT)",
  "description": "抖音短视频大多循环播放，难以可靠检测“播放完成”。本订阅默认用定时上滑实现自动刷下一个；另保留少数结束态/重播提示的触发规则。",
  "rules": [
    {
      "key": 1,
      "name": "抖音自动刷下一个",
      "enable": true,
      "apps": ["com.ss.android.ugc.aweme"],
      "rules": [
        {
          "key": 1,
          "name": "定时上滑刷下一个（12秒）",
          "enable": true,
          "activityIds": [
            "com.ss.android.ugc.aweme.main.MainActivity",
            "com.ss.android.ugc.aweme.detail.ui.DetailActivity"
          ],
          "matches": "[id*='com.ss.android.ugc.aweme:id'][id*='comment']",
          "action": "global:-1",
          "actionCd": 12000
        },

        {
          "key": 10,
          "name": "结束态-id: iv_replay",
          "enable": true,
          "activityIds": [
            "com.ss.android.ugc.aweme.main.MainActivity",
            "com.ss.android.ugc.aweme.detail.ui.DetailActivity"
          ],
          "matches": "[id='com.ss.android.ugc.aweme:id/iv_replay']",
          "action": "global:-1",
          "actionCd": 800
        },
        {
          "key": 11,
          "name": "结束态-id: replay_container",
          "enable": true,
          "activityIds": [
            "com.ss.android.ugc.aweme.main.MainActivity",
            "com.ss.android.ugc.aweme.detail.ui.DetailActivity"
          ],
          "matches": "[id='com.ss.android.ugc.aweme:id/replay_container']",
          "action": "global:-1",
          "actionCd": 800
        },
        {
          "key": 12,
          "name": "结束态-id前缀: replay*",
          "enable": true,
          "activityIds": [
            "com.ss.android.ugc.aweme.main.MainActivity",
            "com.ss.android.ugc.aweme.detail.ui.DetailActivity"
          ],
          "matches": "[id^='com.ss.android.ugc.aweme:id/replay']",
          "action": "global:-1",
          "actionCd": 800
        },
        {
          "key": 20,
          "name": "结束态-文案: 重播",
          "enable": true,
          "activityIds": [
            "com.ss.android.ugc.aweme.main.MainActivity",
            "com.ss.android.ugc.aweme.detail.ui.DetailActivity"
          ],
          "matches": "[text*='重播']",
          "action": "global:-1",
          "actionCd": 800
        },
        {
          "key": 21,
          "name": "结束态-文案: 再看一遍",
          "enable": true,
          "activityIds": [
            "com.ss.android.ugc.aweme.main.MainActivity",
            "com.ss.android.ugc.aweme.detail.ui.DetailActivity"
          ],
          "matches": "[text*='再看一遍']",
          "action": "global:-1",
          "actionCd": 800
        },
        {
          "key": 22,
          "name": "结束态-文案: 播放结束",
          "enable": true,
          "activityIds": [
            "com.ss.android.ugc.aweme.main.MainActivity",
            "com.ss.android.ugc.aweme.detail.ui.DetailActivity"
          ],
          "matches": "[text*='播放结束']",
          "action": "global:-1",
          "actionCd": 800
        }
      ]
    }
  ]
}
